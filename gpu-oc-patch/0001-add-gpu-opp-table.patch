--- a/arch/arm64/boot/dts/qcom/sm8350-taoyao.dtsi
+++ b/arch/arm64/boot/dts/qcom/sm8350-taoyao.dtsi
@@ -1,6 +1,7 @@
 // SPDX-License-Identifier: GPL-2.0-only
 /*
